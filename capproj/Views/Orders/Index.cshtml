@model List<capproj.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<h1>Orders</h1>

<p>
    <a class="btn btn-primary" asp-controller="Orders" asp-action="Create">Create New Order</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Created</th>
            <th>Status</th>
            <th>Type</th>
            <th>Items</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var o in Model)
    {
        <tr>
            <td>@o.Id</td>
            <td>@o.CreatedAt.ToLocalTime().ToString("g")</td>
            <td>@(o.Status ? "Completed" : "Pending")</td>
            <td>@(o.Type ? "Special" : "Standard")</td>
            <td>@(o.orderLines?.Sum(ol => ol.Quantity) ?? 0)</td>
            <td>
                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
