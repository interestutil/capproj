@model capproj.Models.Shelf
@{
    ViewData["Title"] = "Edit Shelf";
}

<h1>Edit Shelf</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DisplayIndex" class="form-label"></label>
        <input asp-for="DisplayIndex" class="form-control" />
        <span asp-validation-for="DisplayIndex" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
