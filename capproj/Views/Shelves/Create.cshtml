@model capproj.Models.Shelf
@{
    ViewData["Title"] = "Create Shelf";
}

<h1>Create Shelf</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DisplayIndex" class="form-label"></label>
        <input asp-for="DisplayIndex" class="form-control" />
        <span asp-validation-for="DisplayIndex" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
