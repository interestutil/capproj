@model capproj.Models.Shelf
@{
    ViewData["Title"] = "Shelf Details";
}

<h1>Shelf Details</h1>

<div class="mb-3">
    <label class="form-label">Id</label>
    <div>@Model.Id</div>
</div>
<div class="mb-3">
    <label class="form-label">Name</label>
    <div>@Model.Name</div>
</div>
<div class="mb-3">
    <label class="form-label">Display Index</label>
    <div>@Model.DisplayIndex</div>
</div>

<h3>Order Lines referencing this shelf</h3>
@if (Model.orderLines != null && Model.orderLines.Any())
{
    <table class="table table-sm">
        <thead><tr><th>Order Id</th><th>Quantity</th></tr></thead>
        <tbody>
        @foreach (var ol in Model.orderLines)
        {
            <tr>
                <td>@ol.OrderId</td>
                <td>@ol.Quantity</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No order lines reference this shelf.</p>
}

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to list</a>
</p>
